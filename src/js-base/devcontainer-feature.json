{
  "id": "js-base",
  "name": "JavaScript Base",
  "version": "1.1.1",
  "description": "Intended to be used with mcr.microsoft.com/devcontainers/javascript-node",
  "documentationURL": "https://github.com/s-h-a-d-o-w/devcontainers-features/tree/main/src/js-base",
  "licenseURL": "https://github.com/s-h-a-d-o-w/devcontainers-features/blob/main/LICENSE",

  "postCreateCommand": "/usr/local/share/js-base-post-create.sh",

  "mounts": [
    {
      // Share the pnpm store across devcontainers. (This host store path should ONLY be used by devcontainers, not the host, to prevent possible security issues.)
      "source": "devcontainer-pnpm-store",
      "target": "/.pnpm-store",
      "type": "volume"
    },
    {
      // Share zsh history
      "source": "devcontainer-zsh-history",
      "target": "/commandhistory",
      "type": "volume"
    }
  ],
  "containerEnv": {
    "pnpm_config_store_dir": "/.pnpm-store"
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      },
      // Extensions that don't work if not installed within the devcontainer
      "extensions": [
        "typescriptteam.native-preview",
        "ms-playwright.playwright",
        "eamodio.gitlens",
        "oxc.oxc-vscode"
      ]
    }
  }
}
