{
    "id": "js-k8s",
    "name": "JavaScript and Kubernetes (and Pulumi)",
    "version": "1.0.6",
    "description": "Intended to be used with mcr.microsoft.com/devcontainers/javascript-node",
    "documentationURL": "https://github.com/s-h-a-d-o-w/devcontainers-features/tree/main/src/js-k8s",
    "licenseURL": "https://github.com/s-h-a-d-o-w/devcontainers-features/blob/main/LICENSE",

    "dependsOn": {
        "ghcr.io/devcontainers-extra/features/direnv:1": {},
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {},
        "ghcr.io/devcontainers-extra/features/pulumi:1": {}
    },

    "postCreateCommand": "curl -o- https://raw.githubusercontent.com/s-h-a-d-o-w/my-os-basics/refs/heads/main/init.sh | bash -s -- no-nvm no-user-host-in-prompt",
    "containerEnv": {
        "pnpm_config_store_dir": "~/.pnpm-store"
    },

    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "zsh"
            },
            // Extensions that don't work if not installed within the devcontainer
            "extensions": [
                "typescriptteam.native-preview",
                "ms-playwright.playwright",
                "eamodio.gitlens",
                "oxc.oxc-vscode"
            ]
        }
    }
}
